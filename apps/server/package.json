{
   "name": "server",
   "module": "index.ts",
   "type": "module",
   "private": true,
   "scripts": {
      "start": "bun run index.ts",
      "dev": "bun run --watch index.ts",
      "worker": "bun run worker.js",
      "seed": "bun run scripts/userSeed.ts && bun run scripts/productSeed.ts && bun run scripts/imageSeed.ts",
      "build": "bun build ./index.ts --target=node --outdir=dist"
   },
