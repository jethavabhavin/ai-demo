      "@types/bcrypt": "^6.0.0",
      "@types/bun": "latest",
      "@types/jsonwebtoken": "^9.0.10"
   },
   "peerDependencies": {
      "typescript": "^5"
   },
   "dependencies": {
      "@fastify/cors": "^11.3.0",
      "@fastify/express": "^4.0.7",
      "@fastify/jwt": "^10.2.0",
      "@fastify/multipart": "^10.1.0",
      "@fastify/swagger": "^9.8.1",
      "@fastify/swagger-ui": "^6.1.0",
      "@google/generative-ai": "^0.24.1",
      "@langchain/community": "^1.1.29",
      "@langchain/core": "^1.2.3",
      "@langchain/google": "^0.2.1",
      "@langchain/google-genai": "^2.2.0",
      "@langchain/openai": "^1.5.5",
      "@langchain/qdrant": "^1.0.3",
      "@qdrant/js-client-rest": "^1.18.0",
      "@types/node": "^26.1.1",
      "bcrypt": "^6.0.0",
      "bullmq": "^5.80.10",
      "dotenv": "^17.4.2",
      "fastify": "^5.10.0",
      "fastify-multer": "^2.0.3",
      "jsonwebtoken": "^9.0.3",
      "langchain": "^1.5.3",
      "mongodb": "6.12.0",
      "multer": "^2.2.0",
